---
import "../styles/techapi.css";

const raw = import.meta.env.BASE_URL;
const base = raw.endsWith("/") ? raw : raw + "/";
const ghUrl = "https://github.com/GetTechAPI/TechAPI";

const endpoints = [
  { label: "/v1/smartphones", desc: "List all phones", href: `${base}v1/smartphones/index.json` },
  { label: "/v1/smartphones/{slug}", desc: "Phone detail + scores", href: `${base}v1/smartphones/galaxy-s25-ultra/index.json` },
  { label: "/v1/smartphones/{slug}/score", desc: "Computed scores", href: `${base}v1/smartphones/galaxy-s25-ultra/score/index.json` },
  { label: "/v1/socs/{slug}", desc: "System-on-chip detail", href: `${base}v1/socs/snapdragon-8-elite/index.json` },
  { label: "/v1/gpus/{slug}", desc: "Discrete GPU detail", href: `${base}v1/gpus/geforce-rtx-5090/index.json` },
  { label: "/v1/cpus/{slug}", desc: "Desktop / laptop CPU", href: `${base}v1/cpus/core-i9-14900k/index.json` },
  { label: "/v1/brands", desc: "All brands", href: `${base}v1/brands/index.json` },
];
---

<!doctype html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <!-- No-flash theme init: saved choice, else OS preference. Runs before paint.
       Inline (no bundling) so it applies before CSS — and it uses no BASE_URL. -->
  <script is:inline>
    (function () {
      try {
        var saved = localStorage.getItem("techapi-theme");
        var theme = saved || (window.matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark");
        document.documentElement.setAttribute("data-theme", theme);
      } catch (e) {}
    })();
  </script>
  <title>TechAPI — open data for consumer electronics specs</title>
  <meta name="description" content="A free, open, static dataset of smartphone, SoC, GPU and CPU specs with computed scores. No key, no server — just fetch JSON." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body>
  <div class="bg-grid" aria-hidden="true"></div>

  <!-- ─────────────── NAV ─────────────── -->
  <nav class="nav">
    <div class="wrap nav-inner">
      <a class="brand" href={base}>
        <span class="mark">T</span>TechAPI<span class="cursor" aria-hidden="true"></span>
      </a>
      <div class="nav-links">
        <a href="#playground">try_it</a>
        <a href="#featured">devices</a>
        <a href="#endpoints">endpoints</a>
        <a href={`${base}docs`}>docs</a>
        <button id="theme-toggle" class="icon-btn" aria-label="Toggle theme" title="Toggle theme">
          <svg class="sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"></path></svg>
          <svg class="moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path></svg>
        </button>
        <a class="nav-gh" href={ghUrl} target="_blank" rel="noopener" title="GitHub" style="padding:7px 10px">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1.1-.7.1-.7.1-.7 1.2 0 1.9 1.2 1.9 1.2 1.1 1.9 2.8 1.3 3.5 1 .1-.8.4-1.3.8-1.6-2.7-.3-5.5-1.3-5.5-5.9 0-1.3.5-2.4 1.2-3.2-.1-.3-.5-1.5.1-3.2 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.6 1.7.2 2.9.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.6-2.8 5.6-5.5 5.9.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0 0 12 .5z"></path></svg>
        </a>
      </div>
    </div>
  </nav>

  <!-- ─────────────── HERO ─────────────── -->
  <header class="hero">
    <div class="wrap hero-grid">
      <div class="hero-copy">
        <span class="kicker">STATIC JSON · NO KEY · NO SERVER</span>
        <h1>
          <span class="ln">Open data</span>
          <span class="ln">for <em>consumer</em></span>
          <span class="ln"><span class="box">electronics</span></span>
        </h1>
        <p class="tagline">Structured specs &amp; computed scores for smartphones, SoCs, GPUs and CPUs — served as plain static JSON. Free and open.</p>
        <div class="hero-cta">
          <a class="btn primary" href="#playground">Try the API <span class="arr">→</span></a>
          <a class="btn" href={`${base}docs`}>Read the docs</a>
        </div>
      </div>

      <div class="hero-term">
        <div class="term">
          <div class="term-bar">
            <span class="tdot"></span><span class="tdot"></span><span class="tdot"></span>
            <span class="tname">~/techapi</span>
            <span class="ttag">LIVE</span>
          </div>
          <div class="term-body">
            <div class="term-cmd" id="term-cmd"></div>
            <div class="term-status" id="term-status"></div>
            <pre class="term-resp"><code id="term-resp"></code></pre>
          </div>
        </div>
      </div>
    </div>

    <div class="wrap">
      <div class="stats" id="stats" data-reveal>
        <div class="stat"><div class="n">—</div><div class="l">loading</div></div>
      </div>
    </div>
  </header>

  <main>
    <!-- ─────────────── PLAYGROUND ─────────────── -->
    <section class="block" id="playground">
      <div class="wrap">
        <div class="sec-head">
          <div>
            <span class="kicker">01 — Playground</span>
            <h2 style="margin-top:14px">Run a request, get JSON</h2>
            <p class="sec-sub">Pick a resource and a slug. The response is fetched straight from the static dataset, right in your browser.</p>
          </div>
          <span class="num">GET /v1/{"{resource}"}/{"{slug}"}</span>
        </div>

        <div class="pg" data-reveal>
          <div class="pg-controls">
            <div class="field">
              <label for="pg-resource">Resource</label>
              <select id="pg-resource">
                <option value="smartphones">smartphones</option>
                <option value="socs">socs</option>
                <option value="gpus">gpus</option>
                <option value="cpus">cpus</option>
                <option value="brands">brands</option>
              </select>
            </div>
            <div class="field grow">
              <label for="pg-slug">Slug</label>
              <input id="pg-slug" list="pg-slugs" autocomplete="off" spellcheck="false" placeholder="galaxy-s25-ultra" />
              <datalist id="pg-slugs"></datalist>
            </div>
            <div class="field btns">
              <button id="pg-send" class="btn primary">Send</button>
              <button id="pg-random" class="btn" title="Random slug">⤮</button>
            </div>
          </div>
          <div class="pg-reqline">
            <span class="method">GET</span>
            <code id="pg-url">/v1/smartphones/galaxy-s25-ultra</code>
            <span class="spacer"></span>
            <span id="pg-status" class="status"></span>
            <button id="pg-copy" class="copy">Copy curl</button>
          </div>
          <pre class="pg-out"><code id="pg-output">Loading…</code></pre>
        </div>
      </div>
    </section>

    <!-- ─────────────── FEATURED ─────────────── -->
    <section class="block" id="featured">
      <div class="wrap">
        <div class="sec-head">
          <div>
            <span class="kicker">02 — Devices</span>
            <h2 style="margin-top:14px">Featured devices</h2>
            <p class="sec-sub">Each card is built from a live detail response. Click one to load it into the playground.</p>
          </div>
        </div>
        <div class="cards" id="cards">
          <div class="skel card-skel"></div><div class="skel card-skel"></div><div class="skel card-skel"></div>
        </div>
      </div>
    </section>

    <!-- ─────────────── ENDPOINTS ─────────────── -->
    <section class="block" id="endpoints">
      <div class="wrap">
        <div class="sec-head">
          <div>
            <span class="kicker">03 — Endpoints</span>
            <h2 style="margin-top:14px">Every resource is a file</h2>
            <p class="sec-sub">No query language, no auth. Each resource is a static file ending in <code>/index.json</code>.</p>
          </div>
        </div>
        <ul class="ep" data-reveal>
          {endpoints.map((e) => (
            <li>
              <a href={e.href}>
                <span class="method">GET</span>
                <span class="ep-path">{e.label}</span>
                <span class="ep-desc">{e.desc}</span>
                <span class="arr">→</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- ─────────────── HOW IT WORKS ─────────────── -->
    <section class="block">
      <div class="wrap">
        <div class="sec-head">
          <div>
            <span class="kicker">04 — How it works</span>
            <h2 style="margin-top:14px">Curated → replayed → served</h2>
          </div>
        </div>
        <div class="hiw" data-reveal>
          <div class="hiw-card"><div class="hiw-n">[ 01 ]</div><h3>Curated data</h3><p>Specs live as reviewed JSON files in the repo, each carrying at least one source URL.</p></div>
          <div class="hiw-card"><div class="hiw-n">[ 02 ]</div><h3>Replayed to disk</h3><p>The real API runs in-process and every response is written out — byte-for-byte identical.</p></div>
          <div class="hiw-card"><div class="hiw-n">[ 03 ]</div><h3>Served from a CDN</h3><p>No server, no cold starts. Just <code>fetch()</code> a file — exactly what this page does.</p></div>
        </div>
      </div>
    </section>

    <!-- ─────────────── END CTA ─────────────── -->
    <section class="block" id="docs">
      <div class="wrap">
        <div class="endcta" data-reveal>
          <span class="kicker" style="justify-content:center">curl techapi.dev/v1/...</span>
          <h2 style="margin-top:18px">Start fetching in one line</h2>
          <p>No sign-up, no rate limit, no SDK. Point <code>fetch()</code> or <code>curl</code> at a URL and you have structured specs. Code is MIT, data is CC-BY-SA 4.0.</p>
          <div class="hero-cta">
            <a class="btn primary" href={ghUrl} target="_blank" rel="noopener">Get it on GitHub <span class="arr">→</span></a>
            <a class="btn" href="#playground">Back to playground</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <!-- ─────────────── FOOTER ─────────────── -->
  <footer>
    <div class="wrap">
      <div class="foot-inner">
        <a class="brand" href={base}><span class="mark">T</span>TechAPI</a>
        <div class="lic">code <strong>MIT</strong> · data <strong>CC-BY-SA 4.0</strong></div>
        <div class="foot-links">
          <a href={ghUrl} target="_blank" rel="noopener">GitHub</a>
          <a href={`${base}docs`}>API reference</a>
          <a href="#playground">Playground</a>
        </div>
      </div>
      <p class="foot-warn">⚠ Curated, growing dataset — not yet an exhaustive catalog of every device.</p>
    </div>
  </footer>

  <script>
    import "../scripts/techapi.js";
  </script>
</body>
</html>
